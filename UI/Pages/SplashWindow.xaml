<Window x:Class="LauncherV2.UI.Pages.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multiworld Launcher"
        Width="420" Height="240"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Border Background="#0D1018"
            BorderBrush="#1E2233"
            BorderThickness="1"
            CornerRadius="6">

        <Grid>
            <!-- Accent top edge -->
            <Border Height="3"
                    VerticalAlignment="Top"
                    CornerRadius="6,6,0,0"
                    HorizontalAlignment="Stretch">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00CCA800" Offset="0"/>
                        <GradientStop Color="#FFCCA800" Offset="0.5"/>
                        <GradientStop Color="#00CCA800" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Content -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <!-- Big AP monogram -->
                <Border Width="64" Height="64"
                        Background="#14172060"
                        BorderBrush="#CCA80050"
                        BorderThickness="1"
                        CornerRadius="8"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <TextBlock Text="AP"
                               FontFamily="Segoe UI"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#CCA800"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <TextBlock Text="MULTIWORLD LAUNCHER"
                           FontFamily="Segoe UI"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#CCA800"
                           HorizontalAlignment="Center"/>

                <!-- Version -->
                <TextBlock x:Name="TxtVersion"
                           Text="v2.0.0"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           Foreground="#505878"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>

                <!-- Update status (hidden until auto-update is downloading) -->
                <TextBlock x:Name="TxtUpdateStatus"
                           Text=""
                           FontFamily="Segoe UI"
                           FontSize="9"
                           Foreground="#CCA800"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           Visibility="Collapsed"/>

                <!-- Animated loading dots -->
                <StackPanel x:Name="LoadingDots"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0">

                    <Ellipse x:Name="Dot1" Width="6" Height="6"
                             Fill="#CCA800" Margin="4,0" Opacity="1"/>
                    <Ellipse x:Name="Dot2" Width="6" Height="6"
                             Fill="#CCA800" Margin="4,0" Opacity="0.3"/>
                    <Ellipse x:Name="Dot3" Width="6" Height="6"
                             Fill="#CCA800" Margin="4,0" Opacity="0.1"/>

                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <!-- Dot 1 pulse -->
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1"
                                                                   Storyboard.TargetProperty="Opacity">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0.0"  Value="1.0"/>
                                        <LinearDoubleKeyFrame KeyTime="0:0:0.4"  Value="0.2"/>
                                        <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="0.1"/>
                                        <LinearDoubleKeyFrame KeyTime="0:0:1.2"  Value="1.0"/>
                                    </DoubleAnimationUsingKeyFrames>
                                    <!-- Dot 2 pulse -->
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2"
                                                                   Storyboard.TargetProperty="Opacity">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0.0"  Value="0.3"/>
                                        <LinearDoubleKeyFrame KeyTime="0:0:0.4"  Value="1.0"/>
                                        <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="0.2"/>
                                        <LinearDoubleKeyFrame KeyTime="0:0:1.2"  Value="0.3"/>
                                    </DoubleAnimationUsingKeyFrames>
                                    <!-- Dot 3 pulse -->
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3"
                                                                   Storyboard.TargetProperty="Opacity">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0.0"  Value="0.1"/>
                                        <LinearDoubleKeyFrame KeyTime="0:0:0.4"  Value="0.3"/>
                                        <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="1.0"/>
                                        <LinearDoubleKeyFrame KeyTime="0:0:1.2"  Value="0.1"/>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                </StackPanel>

            </StackPanel>
        </Grid>
    </Border>
</Window>
