<Window x:Class="LauncherV2.UI.Controls.AchievementToast"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="320" Height="80"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        ResizeMode="NoResize">

    <Border CornerRadius="6"
            Background="#0E1220"
            BorderBrush="#2A3060"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" Opacity="0.5" ShadowDepth="2"/>
        </Border.Effect>
        <Grid Margin="14,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Icon -->
            <TextBlock x:Name="TxtIcon"
                       Grid.Column="0"
                       Text="🏆"
                       FontSize="28"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>

            <!-- Text -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Achievement Unlocked"
                           FontSize="9"
                           FontWeight="SemiBold"
                           Foreground="#F0C040"
                           Opacity="0.85"/>
                <TextBlock x:Name="TxtTitle"
                           Text="Title"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#E0E4F0"
                           Margin="0,2,0,0"/>
                <TextBlock x:Name="TxtDesc"
                           Text="Description"
                           FontSize="10"
                           Foreground="#727A99"
                           TextWrapping="Wrap"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
