<Application x:Class="LauncherV2.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- Global colour palette — change these to restyle the entire launcher.
             Values match the de-facto dark-blue/gold theme used by MainWindow
             and every hardcoded panel (#0D1018 bg / #141720 card / #1E2233
             border / #CCA800 gold / #CCD0E0 text / #727A99 muted). The old
             brown/parchment values painted the main column a different theme
             than the sidebar (P2-15). -->
        <Color x:Key="ColourBackground">#0D1018</Color>
        <Color x:Key="ColourPanel">#141720</Color>
        <Color x:Key="ColourAccent">#CCA800</Color>
        <Color x:Key="ColourText">#CCD0E0</Color>
        <Color x:Key="ColourMuted">#727A99</Color>
        <Color x:Key="ColourSuccess">#22C55E</Color>
        <Color x:Key="ColourError">#D94A4A</Color>

        <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColourBackground}"/>
        <SolidColorBrush x:Key="BrushPanel"      Color="{StaticResource ColourPanel}"/>
        <SolidColorBrush x:Key="BrushAccent"     Color="{StaticResource ColourAccent}"/>
        <SolidColorBrush x:Key="BrushText"       Color="{StaticResource ColourText}"/>
        <SolidColorBrush x:Key="BrushMuted"      Color="{StaticResource ColourMuted}"/>
        <SolidColorBrush x:Key="BrushSuccess"    Color="{StaticResource ColourSuccess}"/>
        <SolidColorBrush x:Key="BrushError"      Color="{StaticResource ColourError}"/>

        <!-- Default text style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>
    </Application.Resources>
</Application>
